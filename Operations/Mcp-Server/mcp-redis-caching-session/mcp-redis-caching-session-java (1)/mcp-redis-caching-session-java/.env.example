# ─────────────────────────────────────────────────────────────────────────────
# Ecoskiller — Redis MCP Server
# Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in your values.
# NEVER commit a filled-in version to source control.
# Use Kubernetes Secrets or GCP Secret Manager to inject these.

# ── Redis Connection ──────────────────────────────────────────────────────────
# GCP MemoryStore:
REDIS_HOST=10.x.x.x
# AWS ElastiCache:
# REDIS_HOST=your-cluster.xyz.ng.0001.use1.cache.amazonaws.com

REDIS_PORT=6379

# Required in production — set via Kubernetes Secret
REDIS_PASSWORD=

# TLS: MUST be true for GCP MemoryStore and AWS ElastiCache
REDIS_TLS_ENABLED=true

# Path to JKS truststore for self-signed certs (leave empty for managed services)
REDIS_TLS_CERT_PATH=

# Redis database index (0-15)
REDIS_DB=0

# ── Connection Pool ───────────────────────────────────────────────────────────
# Max connections in pool (set to 2× expected concurrent MCP calls)
REDIS_MAX_POOL=20

# Socket timeout in ms (keep low for k8s health probes)
REDIS_TIMEOUT_MS=3000

# ── Key Namespace ─────────────────────────────────────────────────────────────
# All Redis keys will be prefixed with this value
REDIS_KEY_PREFIX=ecoskiller

# ── MCP Security ─────────────────────────────────────────────────────────────
# Primary API key — required for every tool call
# Generate: openssl rand -hex 32
MCP_API_KEY=

# Secondary API key for zero-downtime key rotation (optional)
MCP_API_KEY_2=

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG for development, INFO for production, WARN for low-noise
LOG_LEVEL=INFO
