# ─────────────────────────────────────────────────────────────────────────────
# Ecoskiller — Session Control MCP Server Environment Variables
# NEVER commit real values. Use Kubernetes Secrets or GCP Secret Manager.
# ─────────────────────────────────────────────────────────────────────────────

# ── Session-Control-Service Connection ───────────────────────────────────────
# Internal k3s service URL:
SESSION_SERVICE_BASE_URL=http://session-control.realtime.svc.cluster.local:3000
# External (dev):
# SESSION_SERVICE_BASE_URL=http://localhost:3000

SESSION_SERVICE_AUTH_TYPE=bearer    # none | bearer
SESSION_SERVICE_TOKEN=              # Keycloak service-account JWT — inject via k8s secret
SESSION_SERVICE_TLS_VERIFY=true     # false only for local dev with self-signed cert
SESSION_SERVICE_TIMEOUT_MS=10000    # 10 second HTTP timeout

# ── Session Defaults ──────────────────────────────────────────────────────────
SESSION_DEFAULT_TENANT_ID=          # Default tenant context for all operations
SESSION_MAX_DURATION_SECS=14400     # 4 hours max session duration
SESSION_HEARTBEAT_TIMEOUT=120       # 2 minutes — auto-evict if no heartbeat

# ── MCP API Keys ──────────────────────────────────────────────────────────────
MCP_API_KEY=                        # openssl rand -hex 32
MCP_API_KEY_2=                      # Rotation key (optional)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARN | ERROR
