{
  "mcpServers": {
    "mcp-prosody-ecoskiller": {
      "command": "java",
      "args": ["-jar", "/absolute/path/to/prosody-mcp-server/target/prosody-mcp-server-1.0.0.jar"],
      "env": {
        "PROSODY_XMPP_DOMAIN": "ecoskiller.io",
        "PROSODY_DB_HOST": "localhost",
        "PROSODY_REDIS_ENABLED": "false",
        "PROSODY_AUDIT_ENABLED": "true",
        "PROSODY_LOG_LEVEL": "INFO",
        "PROSODY_RATE_LIMIT_PER_SEC": "100",
        "PROSODY_RATE_LIMIT_PER_MIN": "1000"
      }
    }
  }
}
