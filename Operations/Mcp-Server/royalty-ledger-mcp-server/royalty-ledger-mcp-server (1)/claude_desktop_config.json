{
  "mcpServers": {
    "mcp-royalty-ledger-ecoskiller": {
      "command": "java",
      "args": ["-jar", "/absolute/path/to/royalty-ledger-mcp-server/target/royalty-ledger-mcp-server-1.0.0.jar"],
      "env": {
        "ROYALTY_JWT_SECRET":          "your-keycloak-jwt-secret-here",
        "ROYALTY_DOMAIN":              "ecoskiller.io",
        "ROYALTY_DB_HOST":             "localhost",
        "ROYALTY_CLICKHOUSE_HOST":     "localhost",
        "ROYALTY_REDIS_ENABLED":       "false",
        "ROYALTY_AUDIT_ENABLED":       "true",
        "ROYALTY_PAYOUT_THRESHOLD":    "5000",
        "ROYALTY_TDS_RATE_INDIVIDUAL": "10",
        "ROYALTY_TDS_RATE_FOREIGN":    "30",
        "ROYALTY_FRAUD_VELOCITY_LIMIT":"100"
      }
    }
  }
}
