# ─────────────────────────────────────────────────────────────────────────────
# Ecoskiller — Apicurio Schema Registry MCP Server
# Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# NEVER commit real values. Inject via Kubernetes Secrets or GCP Secret Manager.

# ── Apicurio Registry Connection ─────────────────────────────────────────────
# Self-hosted on k3s:
APICURIO_BASE_URL=http://apicurio-registry.schema-registry.svc.cluster.local:8080/apis/registry/v2
# GKE / AWS external:
# APICURIO_BASE_URL=https://schema-registry.ecoskiller.internal/apis/registry/v2

# Auth type: none | basic | bearer
APICURIO_AUTH_TYPE=bearer

# Basic auth (if auth_type=basic)
APICURIO_USERNAME=
APICURIO_PASSWORD=

# Bearer token from Keycloak (if auth_type=bearer)
# In production: inject as a Kubernetes secret, rotated via a sidecar
APICURIO_TOKEN=

# TLS: true in production
APICURIO_TLS_VERIFY=true

# HTTP request timeout
APICURIO_TIMEOUT_MS=10000

# ── Schema Defaults ───────────────────────────────────────────────────────────
APICURIO_DEFAULT_GROUP=ecoskiller
DEFAULT_COMPATIBILITY=BACKWARD
MAX_VERSIONS_WARN=100

# ── MCP API Keys ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
MCP_API_KEY=
MCP_API_KEY_2=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
